---
import FormattedDate from './FormattedDate.astro';
import { getLangFromUrl, getSlugFromId, useTranslatedPath } from '@/i18n/utils';

export interface Props {
	post: any;
}

const { post } = Astro.props;

const currentLang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(currentLang);

const postLink = translatePath(`/blog/${getSlugFromId(post.id)}/`);

const tagLinks = post.data.tags.map((tag: string) => ({
	name: tag,
	link: translatePath(`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`)
}));
---

<li class="list-none">
	<a href={postLink} class="retro-card block group no-underline h-full">
		{post.data.heroImage && (
			<div class="mb-4 rounded overflow-hidden" style="border: 1px solid oklch(78% 0.14 195 / 0.15);">
				<img
					width={720}
					height={360}
					src={post.data.heroImage}
					alt=""
					class="w-full h-48 object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300"
				/>
			</div>
		)}

		{post.data.category && (
			<p class="retro-label mb-2" style="color: var(--retro-amber);">// {post.data.category}</p>
		)}

		<h4
			class="text-xl font-bold mb-2"
			style="color: var(--retro-amber-bright);"
		>
			{post.data.title}
		</h4>

		<p class="font-mono-accent text-xs mb-3" style="color: var(--retro-cyan);">
			<FormattedDate date={post.data.pubDate} />
		</p>

		<p class="text-sm mb-4 leading-relaxed" style="color: oklch(72% 0.02 260);">
			{post.data.description}
		</p>

		{tagLinks.length > 0 && (
			<div class="flex flex-wrap gap-1 mt-auto">
				{tagLinks.map((tag: { name: string, link: string }) => (
					<span class="retro-tag">#{tag.name}</span>
				))}
			</div>
		)}
	</a>
</li>
