---
import BaseHead from '@/components/BaseHead.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts';
import { getCollection } from 'astro:content';
import { filterByLanguage } from '@/i18n/utils';
import RetroHero from '@/components/home/RetroHero.astro';
import RetroPassions from '@/components/home/RetroPassions.astro';
import RetroWritings from '@/components/home/RetroWritings.astro';
import RetroProjects from '@/components/home/RetroProjects.astro';
import RetroCommandCenter from '@/components/home/RetroCommandCenter.astro';

const allProjects = await getCollection('projects');
const featuredProjects = filterByLanguage(allProjects, 'es')
	.filter(project => project.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);

const allPosts = await getCollection('blog');
const latestPosts = filterByLanguage(allPosts, 'es')
	.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
	.slice(0, 3);
---

<!doctype html>
<html lang="es" data-theme="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "WebSite",
					"@id": "https://misaelabanto.com/es/#website",
					"url": "https://misaelabanto.com/es/",
					"name": "Misael Abanto",
					"description": SITE_DESCRIPTION,
					"inLanguage": "es-ES",
					"potentialAction": {
						"@type": "SearchAction",
						"target": {
							"@type": "EntryPoint",
							"urlTemplate": "https://misaelabanto.com/es/blog?q={search_term_string}"
						},
						"query-input": "required name=search_term_string"
					}
				},
				{
					"@type": "Person",
					"@id": "https://misaelabanto.com/#person",
					"name": "Misael Abanto",
					"url": "https://misaelabanto.com",
					"jobTitle": "Ingeniero Fullstack",
					"description": "Ingeniero de software peruano que construye sistemas elegantes, simplifica datos complejos y explora tecnología que empodera a las personas.",
					"sameAs": [
						"https://github.com/misaelabanto",
						"https://linkedin.com/in/misaelabanto",
						"https://twitter.com/_misaelabanto"
					],
					"image": {
						"@type": "ImageObject",
						"url": "https://misaelabanto.com/apple-touch-icon.png"
					}
				}
			]
		})} />
	</head>
	<body>
		<Header />
		<main>
			<RetroHero
				subtitle="Ingeniero Fullstack &middot; Pensador de Sistemas &middot; Humano Curioso"
				description="Construyo sistemas elegantes, simplifico datos complejos y exploro tecnología que empodera a las personas."
				ctaPrimaryText="Leer Transmisiones"
				ctaPrimaryHref="/es/blog"
				ctaSecondaryText="Explorar"
			/>

			<RetroPassions
				heading="Lo Que Alimenta la Señal"
				cards={[
					{ label: 'SECTOR 01', icon: 'mdi:telescope', title: 'Astronomía y Espacio', description: 'Desde los campos profundos del Hubble hasta la termodinámica de agujeros negros — el cosmos es mi fascinación más duradera.', accent: 'amber' },
					{ label: 'SECTOR 02', icon: 'mdi:book-open-page-variant', title: 'Libros y Ciencia Ficción', description: 'Asimov, Baxter, Sawyer, Clarke — historias que doblan la realidad y expanden lo posible.', accent: 'cyan' },
					{ label: 'SECTOR 03', icon: 'mdi:code-braces', title: 'Código y Oficio', description: 'Construir sistemas que son elegantes, confiables y centrados en las personas — el software como disciplina creativa.', accent: 'cyan' },
					{ label: 'SECTOR 04', icon: 'mdi:atom', title: 'Ciencia y Tecnología', description: 'Física, IA, biotecnología — la frontera donde la curiosidad y la ingeniería colisionan.', accent: 'orange' },
				]}
			/>

			<RetroWritings
				sectionLabel="TRANSMISIONES ENTRANTES"
				heading="Últimas Escrituras"
				emptyTitle="Aún no hay transmisiones disponibles."
				emptySubtitle="Nuevas señales próximamente."
				postLabel="TRANSMISIÓN"
				readMore="Leer Más"
				browseAllText="Ver Todas las Transmisiones"
				browseAllHref="/es/blog"
				postBaseHref="/es/blog/"
				posts={latestPosts}
			/>

			<RetroProjects
				sectionLabel="MISIONES ACTIVAS"
				heading="Proyectos Destacados"
				statusLabel="MISIÓN ACTIVA"
				viewAllText="Ver Todas las Misiones"
				viewAllHref="/es/projects"
				projects={featuredProjects}
			/>

			<RetroCommandCenter
				sectionLabel="CENTRO DE COMANDO"
				heading="Sobre Mí y Conexión"
				aboutHeading="Quién Está Detrás de la Señal"
				aboutParagraph1="Soy un ingeniero peruano que cree en el poder de la claridad — en sistemas, escritura y vida. Me encanta construir cosas útiles, aprender obsesivamente y compartir lo que sé."
				aboutParagraph2="Fuera de la tecnología, me gusta la ciencia ficción, la astronomía, planear viajes y hacer la vida cotidiana más eficiente. Desde arquitecturar modelos de datos robustos hasta lanzar MVPs de SaaS, ayudo a los equipos a enviar productos más rápido y de manera más inteligente."
				channelsHeading="Canales Abiertos"
				newsletterLabel="SUSCRÍBETE A LA SEÑAL"
				newsletterDescription="Sin spam. Solo escritura reflexiva sobre datos, software, sistemas y aprendizaje. Un email cada pocas semanas."
				newsletterButtonText="Suscribirse"
				newsletterHref="/es/newsletter"
			/>
		</main>

		<Footer />
	</body>
</html>
