---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts';
import { getCollection } from 'astro:content';
import { filterByLanguage } from '@/i18n/utils';
import RetroHero from '@/components/home/RetroHero.astro';
import RetroPassions from '@/components/home/RetroPassions.astro';
import RetroWritings from '@/components/home/RetroWritings.astro';
import RetroProjects from '@/components/home/RetroProjects.astro';
import RetroCommandCenter from '@/components/home/RetroCommandCenter.astro';

const allProjects = await getCollection('projects');
const featuredProjects = filterByLanguage(allProjects, 'en')
	.filter(project => project.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);

const allPosts = await getCollection('blog');
const latestPosts = filterByLanguage(allPosts, 'en')
	.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
	.slice(0, 3);
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<RetroHero
				subtitle="Fullstack Engineer &middot; System Thinker &middot; Curious Human"
				description="I build elegant systems, simplify complex data, and explore tech that empowers people."
				ctaPrimaryText="Read Transmissions"
				ctaPrimaryHref="/blog"
				ctaSecondaryText="Explore"
			/>

			<RetroPassions
				heading="What Fuels the Signal"
				cards={[
					{ label: 'SECTOR 01', icon: 'mdi:telescope', title: 'Astronomy & Space', description: 'From Hubble deep fields to black hole thermodynamics — the cosmos is my longest-running fascination.', accent: 'amber' },
					{ label: 'SECTOR 02', icon: 'mdi:book-open-page-variant', title: 'Books & Science Fiction', description: "Asimov, Baxter, Sawyer, Clarke — stories that bend reality and expand what's possible.", accent: 'cyan' },
					{ label: 'SECTOR 03', icon: 'mdi:code-braces', title: 'Code & Craft', description: 'Building systems that are elegant, reliable, and human-centered — software as a creative discipline.', accent: 'cyan' },
					{ label: 'SECTOR 04', icon: 'mdi:atom', title: 'Science & Technology', description: 'Physics, AI, biotech — the frontier where curiosity and engineering collide.', accent: 'orange' },
				]}
			/>

			<RetroWritings
				sectionLabel="INCOMING TRANSMISSIONS"
				heading="Latest Writings"
				emptyTitle="No transmissions available yet."
				emptySubtitle="New signals incoming soon."
				postLabel="TRANSMISSION"
				readMore="Read More"
				browseAllText="Browse All Transmissions"
				browseAllHref="/blog"
				postBaseHref="/blog/"
				posts={latestPosts}
			/>

			<RetroProjects
				sectionLabel="ACTIVE MISSIONS"
				heading="Featured Projects"
				statusLabel="MISSION ACTIVE"
				viewAllText="View All Missions"
				viewAllHref="/projects"
				projects={featuredProjects}
			/>

			<RetroCommandCenter
				sectionLabel="COMMAND CENTER"
				heading="About & Connect"
				aboutHeading="Who's Behind the Signal"
				aboutParagraph1="I'm a Peruvian engineer who believes in the power of clarity — in systems, writing, and life. I love building useful things, learning obsessively, and sharing what I know."
				aboutParagraph2="Outside of tech, I'm into science fiction, astronomy, travel planning, and making everyday life more efficient. From architecting robust data models to launching SaaS MVPs, I help teams ship faster and smarter."
				channelsHeading="Open Channels"
				newsletterLabel="SUBSCRIBE TO SIGNAL"
				newsletterDescription="No spam. Just thoughtful writing on data, software, systems, and learning. One email every few weeks."
				newsletterButtonText="Subscribe"
				newsletterHref="/newsletter"
			/>
		</main>

		<Footer />
	</body>
</html>
