---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts';
import { getCollection } from 'astro:content';
import { filterByLanguage } from '@/i18n/utils';
import ThemeManager from '@/components/ThemeManager.astro';
import { Icon } from 'astro-icon/components';

// Get featured projects, sorted by order
const allProjects = await getCollection('projects');
const featuredProjects = filterByLanguage(allProjects, 'en')
	.filter(project => project.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);

// Get latest English blog posts, sorted by date (most recent first)
const allPosts = await getCollection('blog');
const latestPosts = filterByLanguage(allPosts, 'en')
	.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
	.slice(0, 3);
---

<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<ThemeManager />
	</head>
	<body>
		<Header />
		<main>
			<!-- ═══ HERO ═══ -->
			<section
				class="relative min-h-[90vh] flex items-center justify-center overflow-hidden retro-scanlines"
				style="background: linear-gradient(135deg, var(--retro-deep-navy) 0%, var(--retro-navy) 50%, oklch(22% 0.06 240) 100%);"
			>
				<!-- Star field -->
				<div class="absolute inset-0" style="z-index: 0;">
					{Array.from({ length: 60 }).map((_, i) => (
						<div
							class="absolute rounded-full retro-animate-fade"
							style={`
								width: ${1 + (i % 3)}px;
								height: ${1 + (i % 3)}px;
								background: var(--retro-star);
								top: ${(i * 17 + 7) % 100}%;
								left: ${(i * 23 + 13) % 100}%;
								opacity: ${0.3 + (i % 5) * 0.14};
								animation-delay: ${(i % 8) * 0.3}s;
							`}
						/>
					))}
				</div>

				<!-- Perspective grid -->
				<div
					class="absolute inset-0 retro-grid-bg"
					style="opacity: 0.4; mask-image: linear-gradient(to bottom, transparent 10%, black 40%, black 60%, transparent 90%); z-index: 0;"
				></div>

				<!-- Hero content -->
				<div class="relative z-10 text-center px-6 max-w-4xl mx-auto retro-stagger">
					<!-- Status label -->
					<div class="retro-animate-in mb-8 flex items-center justify-center gap-2">
						<span class="retro-pulse-dot"></span>
						<span class="retro-label" style="color: var(--retro-amber);">SIGNAL ACTIVE</span>
					</div>

					<h1
						class="retro-animate-in text-5xl md:text-7xl font-bold mb-6 retro-glow-amber retro-animate-flicker"
						style="color: var(--retro-amber-bright);"
					>
						MISAEL ABANTO
					</h1>

					<p
						class="retro-animate-in font-mono-accent text-lg md:text-xl mb-4"
						style="color: var(--retro-cyan);"
					>
						Fullstack Engineer &middot; System Thinker &middot; Curious Human
					</p>

					<p
						class="retro-animate-in text-base md:text-lg mb-10 max-w-2xl mx-auto"
						style="color: oklch(80% 0.02 260);"
					>
						I build elegant systems, simplify complex data, and explore tech that empowers people.
					</p>

					<!-- CTAs -->
					<div class="retro-animate-in flex flex-wrap justify-center gap-4">
						<a
							href="/blog"
							class="inline-flex items-center gap-2 px-8 py-3 rounded font-mono-accent font-semibold text-sm uppercase tracking-wider transition-all duration-300 hover:scale-105"
							style="background: var(--retro-amber); color: var(--retro-deep-navy);"
						>
							Read Transmissions
						</a>
						<a
							href="#passions"
							class="inline-flex items-center gap-2 px-8 py-3 rounded font-mono-accent font-semibold text-sm uppercase tracking-wider border-2 transition-all duration-300 hover:scale-105"
							style="border-color: var(--retro-cyan); color: var(--retro-cyan);"
						>
							Explore
						</a>
					</div>
				</div>
			</section>

			<!-- ═══ PASSIONS SHOWCASE ═══ -->
			<section
				id="passions"
				class="py-20 px-6 retro-scanlines"
				style="background: var(--retro-navy);"
			>
				<div class="relative z-10 max-w-6xl mx-auto">
					<div class="text-center mb-14 retro-stagger">
						<span class="retro-label retro-animate-in block mb-3" style="color: var(--retro-cyan);">SECTORS OF INTEREST</span>
						<h2 class="retro-animate-in text-3xl md:text-4xl font-bold retro-glow-cyan" style="color: var(--retro-cyan-bright);">
							What Fuels the Signal
						</h2>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-6 retro-stagger">
						<!-- Astronomy & Space -->
						<div class="retro-card retro-animate-in relative overflow-hidden group">
							<div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-10 group-hover:opacity-20 transition-opacity" style="background: radial-gradient(circle, var(--retro-amber) 0%, transparent 70%); transform: translate(30%, -30%);"></div>
							<span class="retro-label block mb-3" style="color: var(--retro-amber);">SECTOR 01</span>
							<div class="flex items-center gap-3 mb-3">
								<Icon name="mdi:telescope" class="w-7 h-7" style="color: var(--retro-amber);" />
								<h3 class="text-xl font-bold" style="color: oklch(92% 0.02 70);">Astronomy & Space</h3>
							</div>
							<p style="color: oklch(70% 0.02 260);">From Hubble deep fields to black hole thermodynamics — the cosmos is my longest-running fascination.</p>
						</div>

						<!-- Books & Science Fiction -->
						<div class="retro-card retro-animate-in relative overflow-hidden group">
							<div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-10 group-hover:opacity-20 transition-opacity" style="background: radial-gradient(circle, var(--retro-cyan) 0%, transparent 70%); transform: translate(30%, -30%);"></div>
							<span class="retro-label block mb-3" style="color: var(--retro-cyan);">SECTOR 02</span>
							<div class="flex items-center gap-3 mb-3">
								<Icon name="mdi:book-open-page-variant" class="w-7 h-7" style="color: var(--retro-cyan);" />
								<h3 class="text-xl font-bold" style="color: oklch(92% 0.02 195);">Books & Science Fiction</h3>
							</div>
							<p style="color: oklch(70% 0.02 260);">Asimov, Le Guin, Liu Cixin — stories that bend reality and expand what's possible.</p>
						</div>

						<!-- Code & Craft -->
						<div class="retro-card retro-animate-in relative overflow-hidden group">
							<div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-10 group-hover:opacity-20 transition-opacity" style="background: radial-gradient(circle, var(--retro-cyan) 0%, transparent 70%); transform: translate(30%, -30%);"></div>
							<span class="retro-label block mb-3" style="color: var(--retro-cyan);">SECTOR 03</span>
							<div class="flex items-center gap-3 mb-3">
								<Icon name="mdi:code-braces" class="w-7 h-7" style="color: var(--retro-cyan);" />
								<h3 class="text-xl font-bold" style="color: oklch(92% 0.02 195);">Code & Craft</h3>
							</div>
							<p style="color: oklch(70% 0.02 260);">Building systems that are elegant, reliable, and human-centered — software as a creative discipline.</p>
						</div>

						<!-- Science & Technology -->
						<div class="retro-card retro-animate-in relative overflow-hidden group">
							<div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-10 group-hover:opacity-20 transition-opacity" style="background: radial-gradient(circle, var(--retro-orange) 0%, transparent 70%); transform: translate(30%, -30%);"></div>
							<span class="retro-label block mb-3" style="color: var(--retro-orange);">SECTOR 04</span>
							<div class="flex items-center gap-3 mb-3">
								<Icon name="mdi:atom" class="w-7 h-7" style="color: var(--retro-orange);" />
								<h3 class="text-xl font-bold" style="color: oklch(92% 0.02 50);">Science & Technology</h3>
							</div>
							<p style="color: oklch(70% 0.02 260);">Physics, AI, biotech — the frontier where curiosity and engineering collide.</p>
						</div>
					</div>
				</div>
			</section>

			<hr class="retro-divider" />

			<!-- ═══ LATEST WRITINGS ═══ -->
			<section
				class="py-20 px-6 retro-grid-bg retro-scanlines"
				style="background-color: var(--retro-deep-navy);"
			>
				<div class="relative z-10 max-w-6xl mx-auto">
					<div class="text-center mb-14 retro-stagger">
						<span class="retro-label retro-animate-in block mb-3" style="color: var(--retro-amber);">INCOMING TRANSMISSIONS</span>
						<h2 class="retro-animate-in text-3xl md:text-4xl font-bold retro-glow-amber" style="color: var(--retro-amber-bright);">
							Latest Writings
						</h2>
					</div>

					{latestPosts.length === 0 ? (
						<div class="text-center py-8">
							<p class="text-lg mb-4" style="color: oklch(70% 0.02 260);">No transmissions available yet.</p>
							<p class="text-sm" style="color: oklch(55% 0.02 260);">New signals incoming soon.</p>
						</div>
					) : (
						<div class="grid grid-cols-1 md:grid-cols-3 gap-6 retro-stagger">
							{latestPosts.map((post) => (
								<a href={`/blog/${post.id.split('/')[1]}`} class="retro-card retro-animate-in block group no-underline">
									<span class="retro-label block mb-3" style="color: var(--retro-cyan);">TRANSMISSION</span>
									<h3 class="text-lg font-bold mb-2 group-hover:retro-glow-cyan transition-all" style="color: oklch(92% 0.02 260);">
										{post.data.title}
									</h3>
									<p class="text-sm mb-4" style="color: oklch(65% 0.02 260);">{post.data.description}</p>
									<span class="font-mono-accent text-xs uppercase tracking-wider" style="color: var(--retro-amber);">
										Read More &rarr;
									</span>
								</a>
							))}
						</div>
					)}

					<div class="text-center mt-14">
						<a
							href="/blog"
							class="inline-flex items-center gap-2 px-8 py-3 rounded font-mono-accent font-semibold text-sm uppercase tracking-wider transition-all duration-300 hover:scale-105"
							style="background: var(--retro-amber); color: var(--retro-deep-navy);"
						>
							Browse All Transmissions
						</a>
					</div>
				</div>
			</section>

			<!-- ═══ FEATURED PROJECTS ═══ -->
			<section id="projects" class="py-20 px-6 bg-base-100">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-14 retro-stagger">
						<span class="retro-label retro-animate-in block mb-3 text-base-content/50">ACTIVE MISSIONS</span>
						<h2 class="retro-animate-in text-3xl md:text-4xl font-bold text-base-content">
							Featured Projects
						</h2>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-3 gap-6 retro-stagger">
						{featuredProjects.map((project) => (
							<div class="retro-animate-in rounded-lg border border-base-300 bg-base-200 p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
								<div class="flex items-center gap-2 mb-3">
									<span class="retro-pulse-dot"></span>
									<span class="retro-label text-base-content/50">MISSION ACTIVE</span>
								</div>
								<h3 class="text-xl font-bold mb-2 text-base-content">{project.data.title.split(' - ')[0]}</h3>
								<p class="text-base-content/70 mb-4">{project.data.description}</p>
								<div class="flex gap-2 flex-wrap">
									{project.data.category && (
										<span
											class="font-mono-accent text-xs px-2 py-1 rounded"
											style="background: oklch(78% 0.16 70 / 0.15); color: var(--retro-amber);"
										>
											{project.data.category}
										</span>
									)}
									{project.data.technologies.slice(0, 2).map((tech) => (
										<span
											class="font-mono-accent text-xs px-2 py-1 rounded"
											style="background: oklch(78% 0.14 195 / 0.15); color: var(--retro-cyan);"
										>
											{tech}
										</span>
									))}
								</div>
							</div>
						))}
					</div>

					<div class="text-center mt-14">
						<a
							href="/projects"
							class="inline-flex items-center gap-2 px-8 py-3 rounded font-mono-accent font-semibold text-sm uppercase tracking-wider border-2 border-base-content/20 text-base-content transition-all duration-300 hover:scale-105 hover:border-base-content/40"
						>
							View All Missions
						</a>
					</div>
				</div>
			</section>

			<!-- ═══ COMMAND CENTER (About + Contact + Newsletter) ═══ -->
			<section
				class="py-20 px-6 retro-scanlines"
				style="background: var(--retro-navy);"
			>
				<div class="relative z-10 max-w-6xl mx-auto">
					<div class="text-center mb-14 retro-stagger">
						<span class="retro-label retro-animate-in block mb-3" style="color: var(--retro-cyan);">COMMAND CENTER</span>
						<h2 class="retro-animate-in text-3xl md:text-4xl font-bold retro-glow-cyan" style="color: var(--retro-cyan-bright);">
							About & Connect
						</h2>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
						<!-- Left: About -->
						<div class="retro-animate-in">
							<h3 class="text-xl font-bold mb-4" style="color: var(--retro-amber);">Who's Behind the Signal</h3>
							<p class="mb-4 leading-relaxed" style="color: oklch(75% 0.02 260);">
								I'm a Peruvian engineer who believes in the power of clarity — in systems, writing, and life.
								I love building useful things, learning obsessively, and sharing what I know.
							</p>
							<p class="leading-relaxed" style="color: oklch(75% 0.02 260);">
								Outside of tech, I'm into science fiction, astronomy, travel planning, and making everyday life more efficient.
								From architecting robust data models to launching SaaS MVPs, I help teams ship faster and smarter.
							</p>
						</div>

						<!-- Right: Social links -->
						<div class="retro-animate-in">
							<h3 class="text-xl font-bold mb-4" style="color: var(--retro-cyan);">Open Channels</h3>
							<div class="flex flex-col gap-3">
								<a href="https://x.com/_misaelabanto" target="_blank" class="retro-card flex items-center gap-4 no-underline !py-3 !px-4">
									<Icon name="simple-icons:x" class="w-5 h-5" style="color: var(--retro-cyan);" />
									<span class="font-mono-accent text-sm" style="color: oklch(80% 0.02 260);">@_misaelabanto</span>
								</a>
								<a href="https://linkedin.com/in/misaelabanto" target="_blank" class="retro-card flex items-center gap-4 no-underline !py-3 !px-4">
									<Icon name="simple-icons:linkedin" class="w-5 h-5" style="color: var(--retro-cyan);" />
									<span class="font-mono-accent text-sm" style="color: oklch(80% 0.02 260);">misaelabanto</span>
								</a>
								<a href="https://github.com/misaelabanto" target="_blank" class="retro-card flex items-center gap-4 no-underline !py-3 !px-4">
									<Icon name="simple-icons:github" class="w-5 h-5" style="color: var(--retro-cyan);" />
									<span class="font-mono-accent text-sm" style="color: oklch(80% 0.02 260);">misaelabanto</span>
								</a>
								<a href="https://t.me/misaelabanto" target="_blank" class="retro-card flex items-center gap-4 no-underline !py-3 !px-4">
									<Icon name="simple-icons:telegram" class="w-5 h-5" style="color: var(--retro-cyan);" />
									<span class="font-mono-accent text-sm" style="color: oklch(80% 0.02 260);">misaelabanto</span>
								</a>
								<a href="mailto:hi@misaelabanto.com" class="retro-card flex items-center gap-4 no-underline !py-3 !px-4">
									<Icon name="mdi:email" class="w-5 h-5" style="color: var(--retro-cyan);" />
									<span class="font-mono-accent text-sm" style="color: oklch(80% 0.02 260);">hi@misaelabanto.com</span>
								</a>
							</div>
						</div>
					</div>

					<!-- Newsletter CTA -->
					<div class="mt-14 text-center retro-card !border-amber-500/20">
						<span class="retro-label block mb-3" style="color: var(--retro-amber);">SUBSCRIBE TO SIGNAL</span>
						<p class="mb-6" style="color: oklch(70% 0.02 260);">
							No spam. Just thoughtful writing on data, software, systems, and learning. One email every few weeks.
						</p>
						<a
							href="/newsletter"
							class="inline-flex items-center gap-2 px-8 py-3 rounded font-mono-accent font-semibold text-sm uppercase tracking-wider transition-all duration-300 hover:scale-105"
							style="background: var(--retro-amber); color: var(--retro-deep-navy);"
						>
							Subscribe
						</a>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
