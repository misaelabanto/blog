---
import BlogFilteredPage from '@/components/pages/BlogFilteredPage.astro';
import { filterByLanguage } from '@/i18n/utils';
import { getUI } from '@/i18n/ui';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const posts = filterByLanguage(allPosts, 'en');
	const categories = [...new Set(posts.map((post) => post.data.category))];

	return categories.map((category) => ({
		params: { category: category.toLowerCase().replace(/\s+/g, '-') },
		props: {
			posts: posts.filter((post) => post.data.category === category),
			category,
		},
	}));
}

const { posts, category } = Astro.props;
const t = getUI('en');
---

<BlogFilteredPage
	lang="en"
	heading={category}
	browserTitle={`${category} · Blog`}
	metaDescription={(t['blog.categoryMetaDescription'] as (c: number, s: string) => string)(posts.length, category)}
	posts={posts}
/>
