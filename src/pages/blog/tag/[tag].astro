---
import BlogFilteredPage from '@/components/pages/BlogFilteredPage.astro';
import { filterByLanguage } from '@/i18n/utils';
import { getUI } from '@/i18n/ui';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const posts = filterByLanguage(allPosts, 'en');
	const uniqueTags = [...new Set(posts.flatMap((post) => post.data.tags))];

	return uniqueTags.map((tag) => ({
		params: { tag: tag.toLowerCase().replace(/\s+/g, '-') },
		props: {
			posts: posts.filter((post) => post.data.tags.includes(tag)),
			tag,
		},
	}));
}

const { posts, tag } = Astro.props;
const t = getUI('en');
---

<BlogFilteredPage
	lang="en"
	heading={`#${tag}`}
	browserTitle={`#${tag} · Blog`}
	metaDescription={(t['blog.tagMetaDescription'] as (c: number, s: string) => string)(posts.length, tag)}
	posts={posts}
	activeTag={tag}
/>
