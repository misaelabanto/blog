---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '@/components/BaseHead.astro';
import BlogSEO from '@/components/BlogSEO.astro';
import Footer from '@/components/Footer.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import Header from '@/components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	lang?: string;
	slug?: string;
};

const { title, description, pubDate, updatedDate, heroImage, category, tags = [], lang = 'en', slug = '', draft = false } = Astro.props;
---

<html lang={lang} data-theme="dark">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			publishedTime={pubDate}
			modifiedTime={updatedDate}
			author="Misael Abanto"
			section={category}
			tags={tags}
			noindex={draft}
		/>
		<BlogSEO
			title={title}
			description={description}
			pubDate={pubDate}
			updatedDate={updatedDate}
			heroImage={heroImage}
			category={category}
			tags={tags}
			lang={lang}
			slug={slug}
		/>
	</head>

	<body class="flex flex-col min-h-screen retro-scanlines" style="background: var(--retro-deep-navy);">
		<Header />
		<main class="flex-grow">
			<!-- Post Header -->
			<section
				class="relative py-16 px-6 retro-grid-bg"
				style="background: linear-gradient(180deg, var(--retro-deep-navy) 0%, var(--retro-navy) 100%);"
			>
				<div class="max-w-3xl mx-auto retro-stagger">
					{category && (
						<div class="retro-animate-in mb-4">
							<a
								href={`${lang === 'es' ? '/es' : ''}/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}`}
								class="retro-label hover:opacity-80 transition-opacity"
								style="color: var(--retro-amber);"
							>
								// {category}
							</a>
						</div>
					)}

					<h1
						class="retro-animate-in text-3xl md:text-5xl font-bold mb-6 retro-glow-amber"
						style="color: var(--retro-amber-bright);"
					>
						{title}
					</h1>

					<p class="retro-animate-in font-mono-accent text-sm mb-6" style="color: var(--retro-cyan);">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="opacity-60 ml-4">· Updated <FormattedDate date={updatedDate} /></span>
						)}
					</p>

					{tags.length > 0 && (
						<div class="retro-animate-in flex flex-wrap gap-2 mb-8">
							{tags.map((tag: string) => (
								<a
									href={`${lang === 'es' ? '/es' : ''}/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
									class="retro-tag hover:opacity-80 transition-opacity"
								>
									#{tag}
								</a>
							))}
						</div>
					)}

					<hr class="retro-divider" />
				</div>
			</section>

			<!-- Hero Image -->
			{heroImage && (
				<div class="max-w-3xl mx-auto px-4 sm:px-6 pt-8">
					<div class="rounded-lg overflow-hidden" style="border: 1px solid oklch(78% 0.14 195 / 0.2);">
						<img width={1020} height={510} src={heroImage} alt={`Hero image for ${title}`} class="w-full" />
					</div>
				</div>
			)}

			<!-- Content -->
			<article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
				<div class="prose prose-invert lg:prose-xl mx-auto
					prose-headings:font-sans prose-headings:text-amber-300 prose-headings:font-bold
					prose-a:text-cyan-400 prose-a:no-underline hover:prose-a:underline
					prose-code:text-cyan-300
					prose-blockquote:border-l-4 prose-blockquote:border-amber-500/60 prose-blockquote:text-gray-300
					prose-strong:text-amber-200">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
